{
  "server": {
    "serverId": "sum-smoke-server",
    "advertiseHost": "127.0.0.1",
    "discoveryMulticastAddress": "239.0.0.222",
    "discoveryPort": 15001,
    "tcpPort": 15000,
    "maxConcurrentSessions": 32,
    "clientResponseTimeoutSeconds": 10
  },
  "suite": {
    "groups": [
      {
        "id": "sum-basic",
        "name": "Addition smoke tests",
        "testcases": [
          {
            "id": "sum-expected-001",
            "comparisonMode": "strict-json",
            "input": {
              "mode": "inline",
              "value": {
                "a": 2,
                "b": 3
              }
            },
            "expectedOutput": 5
          },
          {
            "id": "sum-golden-001",
            "comparisonMode": "strict-json",
            "input": {
              "mode": "inline",
              "value": {
                "a": 10,
                "b": -4
              }
            },
            "goldenStandard": {
              "sourceFile": "sum-golden-standard.cs",
              "typeName": "GoldenStandard",
              "methodName": "Solve"
            }
          }
        ]
      },
      {
        "id": "sum-random",
        "name": "Addition random smoke tests",
        "random": {
          "count": 3,
          "testCaseIdPrefix": "sum-random-",
          "seed": 20260218,
          "comparisonMode": "strict-json",
          "goldenStandard": {
            "sourceFile": "sum-golden-standard.cs",
            "typeName": "GoldenStandard",
            "methodName": "Solve"
          },
          "inputGenerator": {
            "mode": "default",
            "intFields": [
              {
                "name": "a",
                "min": -100,
                "max": 100
              },
              {
                "name": "b",
                "min": -100,
                "max": 100
              }
            ]
          }
        }
      },
      {
        "id": "sum-random-script",
        "name": "Addition random smoke tests (script generator)",
        "random": {
          "count": 3,
          "testCaseIdPrefix": "sum-random-script-",
          "seed": 20260219,
          "comparisonMode": "strict-json",
          "goldenStandard": {
            "sourceFile": "sum-golden-standard.cs",
            "typeName": "GoldenStandard",
            "methodName": "Solve"
          },
          "inputGenerator": {
            "mode": "source-file",
            "sourceFile": "sum-random-input-generator.cs",
            "typeName": "RandomInputGenerator",
            "methodName": "Generate"
          }
        }
      }
    ]
  }
}
